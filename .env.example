# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase
# (Project Settings > API no painel do Supabase)

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Nunca coloque a service_role key aqui — ela nunca deve ir para o frontend.
